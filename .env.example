# Whop OAuth app credentials (Whop dashboard -> Developer -> your app)
WHOP_OAUTH_CLIENT_ID=app_XXXXXXXXXXXX
WHOP_OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Company API key — optional fallback for server-side membership lookups
# if the user OAuth token cannot list memberships itself.
WHOP_API_KEY=

# Must exactly match the redirect URI configured on the Whop OAuth app.
REDIRECT_URI=https://dashboard.onetimesuite.com/callback

# Random long string used to sign the session cookie (e.g. `openssl rand -hex 32`)
SESSION_SECRET=change-me-to-a-long-random-string

PORT=5375
